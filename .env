# ========== 推理后端（默认：本地 Ollama，完全免费、离线、调用本机 GPU）==========
# LLM_BACKEND 可选值：
#   ollama      （默认）本地 Ollama 运行开源模型，免费/离线/GPU，无需任何 API Key
#   siliconflow 硅基流动在线API，需要 SILICONFLOW_API_KEY（保留作备选）
#   local_lora  本地 Qwen2.5-0.5B + LoRA 适配器（CPU，需先训练）
LLM_BACKEND=ollama

# Ollama 服务地址（默认本机）；模型需先拉取：ollama pull deepseek-r1 和 ollama pull nomic-embed-text
OLLAMA_HOST=http://localhost:11434
# Ollama 可执行文件路径（自动拉取模型时使用，一般无需改动）
OLLAMA_BIN=ollama

# 对话模型（当前用本机已装的 deepseek-r1，无需额外下载；显存够可换更大模型如 qwen2.5:14b 提升事实准确性）
# 当前使用本机已装的 deepseek-r1，无需额外下载
LLM_MODEL=deepseek-r1

# ========== 向量化（本地 Ollama nomic-embed-text，免费/离线）==========
# nomic-embed-text：768 维，英文/通用检索效果优秀
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ========== 重排（本地 RRF 倒数排名融合，免费/离线/无需模型）==========
# RRF 综合「向量检索」与「BM25 关键词检索」两套排名，比简单加权更稳健
# 可选：cross_encoder（若已装本地交叉编码器可作增强，默认 rrf）
RERANKER=rrf
# 是否启用重排（true 启用 RRF；false 则走向量+BM25 加权融合）
USE_RERANKER=true

# ========== SiliconFlow 在线API（仅 LLM_BACKEND=siliconflow 时使用，可留空）==========
# 免费获取：https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=
# 在线对话模型（silliconflow 模式用）
# LLM_MODEL_SF=Qwen/Qwen2.5-14B-Instruct

# ========== 本地 LoRA 推理模式（LLM_BACKEND=local_lora 时使用，可留空）==========
LLM_LOCAL_MODEL=./models/base/Qwen/Qwen2.5-0.5B-Instruct
LLM_LORA_PATH=./models/lora/qwen2.5-0.5b-lora-v1

# ========== Redis配置 ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========== 服务配置 ==========
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SECRET_KEY=my-super-secret-key-change-this-in-production

# ========== 默认账号（首次启动自动创建，可用前端登录）==========
DEFAULT_USERNAME=xuanxu
DEFAULT_PASSWORD=xuanxu123

# ========== 数据路径 ==========
VECTOR_DB_PATH=./data/vector_db
DOCUMENT_STORAGE_PATH=./data/raw
